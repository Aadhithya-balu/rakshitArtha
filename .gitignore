# Global ignore rules for monorepo

# Dependencies
**/node_modules/

# Environment and secrets
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.template

# Logs and runtime artifacts
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Coverage and reports
**/coverage/
**/.nyc_output/

# Build outputs
**/dist/
**/build/

# React Native / Android / iOS generated artifacts
FRONTEND/android/.gradle/
FRONTEND/android/app/build/
FRONTEND/android/build/
FRONTEND/ios/build/

# Firebase client config files (store privately)
FRONTEND/android/app/google-services.json
FRONTEND/ios/GoogleService-Info.plist

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
