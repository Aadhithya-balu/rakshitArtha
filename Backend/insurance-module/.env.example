MONGODB_URI=mongodb://localhost:27017/parametric-insurance
PORT=5000
NODE_ENV=development
AUTOMATION_API_URL=http://localhost:3000
AUTOMATION_SYNC_TOKEN=change_this_shared_sync_token

# Risk Prediction Service
RISK_PREDICTION_API=http://localhost:8000

# Weather API Integration
# Get from: https://openweathermap.org/api (Free tier available)
WEATHER_API_KEY=your_openweather_api_key

# IMD API (India Meteorological Department)
# Get from: https://mausam.imd.gov.in/ (Government API - may require registration)
IMD_API_ENDPOINT=https://api.imd.gov.in

# Location Service
# Get from: https://console.cloud.google.com/google/maps-apis (Google Maps API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Security
# Generate a secure random string for JWT (use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_long_random_secret

# Razorpay (Test Mode)
# Get test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_test_secret

# Insurer admin login defaults
INSURER_ADMIN_EMAIL=insurer.admin@rakshitartha.in
INSURER_ADMIN_NAME=RakshitArtha Insurer Admin
INSURER_ADMIN_PASSWORD=change_this_admin_password
INSURER_ADMIN_BOOTSTRAP_SECRET=change_this_bootstrap_secret

# API Key for external service authentication
API_KEY=your_external_api_key_here
